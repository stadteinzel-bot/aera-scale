rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Org-scoped document storage: /documents/{orgId}/...
    // Only authenticated users who belong to the org can read/write.
    // Org membership is enforced at the Firestore level;
    // here we enforce auth + path-based org scoping + size/type limits.
    match /documents/{orgId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches(
             '(image/.*|application/pdf|application/vnd\\..*|text/.*)');
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
