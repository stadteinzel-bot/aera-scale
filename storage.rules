rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Any authenticated upload under /documents/... is allowed as long as:
    // 1. User is signed in
    // 2. File ≤ 25 MB
    // 3. Content type is image, PDF, or Office document
    // Org-level quota is enforced client-side via storageQuota.ts + Firestore counter.
    match /documents/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches(
             '(image/.*|application/pdf|application/vnd\\..*|text/.*)');
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
